# Use LF for text files across the repo to avoid Windows CRLF churn.
* text=auto eol=lf

# Keep common Windows shell/project formats in CRLF when checked out.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Unity and code/text assets (explicit for clarity).
*.cs text eol=lf
*.meta text eol=lf
*.unity text eol=lf
*.prefab text eol=lf
*.asset text eol=lf
*.mat text eol=lf
*.anim text eol=lf
*.controller text eol=lf
*.asmdef text eol=lf
*.asmref text eol=lf
*.shader text eol=lf
*.compute text eol=lf
*.hlsl text eol=lf
*.cginc text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary assets should never be line-normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.tga binary
*.psd binary
*.exr binary
*.fbx binary
*.blend binary
*.wav binary
*.mp3 binary
*.ogg binary
*.mp4 binary
*.mov binary
*.unitypackage binary
*.zip binary
*.7z binary
*.rar binary
*.tar binary
*.gz binary

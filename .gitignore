# Common oversized distribution archives (Git cannot ignore by file size, so ignore by artifact type)
*.unitypackage
*.unitypackage.meta
*.zip
*.zip.meta
*.7z
*.7z.meta
*.rar
*.rar.meta
*.tar
*.tar.meta
*.gz
*.gz.meta
*.tgz
*.tgz.meta

# Ignore raw third-party package archives; keep imported project assets tracked.
Assets/ThirdParty/**/*.unitypackage
Assets/ThirdParty/**/*.unitypackage.meta
Assets/GameReady3D/**/*.unitypackage
Assets/GameReady3D/**/*.unitypackage.meta

